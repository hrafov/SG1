import java.util.ArrayList;
import java.util.List;
import java.util.Random;

public class SG11 {
    // codewars.com/kata/59669eba1b229e32a300001a/train/java - 3
    public static String wireDHD(String existingWires) {
        char[][] matrix = matrixFromExistingWiresString(existingWires);
        System.out.println("original charMatrix:");
        printCharMatrix(matrix);

        Point currentMove = findPoint(matrix, 'S');
        Point goal = findPoint(matrix, 'G');
        int howLongIsCurrentWay = Integer.MAX_VALUE;
        String resultShortestWay = "noWay";

        for (var variant = 0; variant < 1; variant++) { // TODO this cycle for different variants = matrix.length * matrix[0].length
            var stepsInStochasticWay = 0;
            for (var times = 0; times < 5; times++) { // TODO this cycle stochastic try = matrix.length * matrix[0].length
                currentMove = findNewMoveFromCurrentAndChangeMatrix(currentMove, matrix);
                if (currentMove == null) break;
                if (currentMove.equals(goal)) {
                    howLongIsCurrentWay = stepsInStochasticWay;
                    break;
                }
                matrix[currentMove.j()][currentMove.i()] = 'P';
                stepsInStochasticWay++;
            }
            if (stepsInStochasticWay < howLongIsCurrentWay) {
                howLongIsCurrentWay = stepsInStochasticWay;
                resultShortestWay = stringFromMatrix(matrix);
            }
        }
        if (resultShortestWay.equals("noWay")) return "Oh for crying out loud...";
        else return  resultShortestWay;
    }

    private static String stringFromMatrix(char[][] matrix) {
        StringBuilder sb = new StringBuilder();
        for (char[] chars : matrix) {
            for (var j = 0; j < matrix[0].length; j++) sb.append(chars[j]);
            sb.append("\n");
        }
        return sb.toString().trim();
    }

    private static Point findNewMoveFromCurrentAndChangeMatrix(Point currentMove, char[][] matrix) {
        // for every 0-7 directions find if free space '.' and add this point to list, if not, go father
        List<Point> listOfFreePointsAroundCurrentPoint = new ArrayList<>();
        // 0
        if (currentMove.j() != 0 && matrix[currentMove.j() - 1][currentMove.i()] == '.')
            listOfFreePointsAroundCurrentPoint.add(new Point(currentMove.j() - 1, currentMove.i()));
        // 1
        if (currentMove.j() != 0 && currentMove.i() != matrix[0].length && matrix[currentMove.j() - 1][currentMove.i() + 1] == '.')
            listOfFreePointsAroundCurrentPoint.add(new Point(currentMove.j() - 1, currentMove.i() + 1));
        // 2
        if (currentMove.i() != matrix[0].length && matrix[currentMove.j()][currentMove.i() + 1] == '.')
            listOfFreePointsAroundCurrentPoint.add(new Point(currentMove.j(), currentMove.i() + 1));
        // 3
        if (currentMove.j() != matrix.length && currentMove.i() != matrix[0].length && matrix[currentMove.j() + 1][currentMove.i() + 1] == '.')
            listOfFreePointsAroundCurrentPoint.add(new Point(currentMove.j() + 1, currentMove.i() + 1));
        // 4
        if (currentMove.j() != matrix.length && matrix[currentMove.j() - 1][currentMove.i()] == '.')
            listOfFreePointsAroundCurrentPoint.add(new Point(currentMove.j() + 1, currentMove.i()));
        // 5
        if (currentMove.j() != matrix.length && currentMove.i() != 0 && matrix[currentMove.j() + 1][currentMove.i() - 1] == '.')
            listOfFreePointsAroundCurrentPoint.add(new Point(currentMove.j() + 1, currentMove.i() - 1));
        // 6
        if (currentMove.i() != 0 && matrix[currentMove.j()][currentMove.i() - 1] == '.')
            listOfFreePointsAroundCurrentPoint.add(new Point(currentMove.j(), currentMove.i() - 1));
        // 7
        if (currentMove.j() != 0 && currentMove.i() != 0 && matrix[currentMove.j() - 1][currentMove.i() - 1] == '.')
            listOfFreePointsAroundCurrentPoint.add(new Point(currentMove.j() - 1, currentMove.i() - 1));

        Random rand = new Random();
        int randomPointIndex = rand.nextInt(listOfFreePointsAroundCurrentPoint.size() - 1);
        if (listOfFreePointsAroundCurrentPoint.isEmpty()) return null;
        else return listOfFreePointsAroundCurrentPoint.get(randomPointIndex);
    }

    private static Point findPoint(char[][] matrix, char goal) {
        for (int i = 0; i < matrix.length; i++)
            for (int j = 0; j < matrix[0].length; j++)
                if (matrix[i][j] == goal) return new Point(j, i);
        return null;
    }

    private static char[][] matrixFromExistingWiresString(String existingWires) {
        char[][] matrix = new char[existingWires.split("\n").length][existingWires.split("\n")[0].length()];
        int row = 0;
        for (String rowString : existingWires.split("\n")) {
            for (int col = 0; col < rowString.length(); col++) matrix[row][col] = rowString.charAt(col);
            row++;
        }
        return matrix;
    }

    private static void printCharMatrix(char[][] matrix) {
        for (char[] chars : matrix) {
            for (var j = 0; j < matrix[0].length; j++) System.out.print(chars[j]);
            System.out.println();
        }
        System.out.println();
    }

    private static void printMatrix(String s) {
        for (String row : s.split("\n")) {
            System.out.println(row);
        }
        System.out.println();
    }

    public static void main(String[] args) {
        String existingWires = "...\n" +
                "S.G\n" +
                "...";

        String solution = "...\n" +
                "SPG\n" +
                "...";
        System.out.println(wireDHD(existingWires));

        // test
